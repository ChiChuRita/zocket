---
import { Code } from "astro:components";

interface Props {
  title: string;
  code: string;
  lang?: string;
  label?: string;
  variant?: "default" | "brand";
  maxHeight?: string;
}

const {
  title,
  code,
  lang = "typescript",
  label,
  variant = "default",
  maxHeight = "min(50vh, 28rem)",
} = Astro.props;
---

<div class:list={["code-frame flex h-full w-full flex-col overflow-hidden", variant === "brand" && "code-frame--brand"]}>
  <div class="code-header">
    <div class="code-header__dots">
      <span></span><span></span><span></span>
    </div>
    <span class="code-header__title">{title}</span>
    {label ? (
      <span
        class:list={[
          "rounded-full px-2 py-0.5 font-mono text-[10px]",
          variant === "brand"
            ? "bg-brand/10 text-brand"
            : "bg-fg/[0.06] text-fg-subtle",
        ]}
      >
        {label}
      </span>
    ) : (
      <span class="w-10"></span>
    )}
  </div>
  <div class="code-body" style={`max-height: ${maxHeight};`}>
    <Code code={code.trim()} lang={lang} theme="github-dark" />
  </div>
</div>
