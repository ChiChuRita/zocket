---
import { Code } from "astro:components";

interface Props {
  title: string;
  code: string;
  lang?: string;
}

const { title, code, lang = "typescript" } = Astro.props;
---

<div class="code-frame flex w-full flex-col rounded-2xl border border-white/[0.08] bg-[#0d0d0d]/92 shadow-[0_24px_80px_rgba(0,0,0,0.45)] backdrop-blur-md transition-colors duration-300 hover:border-white/[0.12]">
  <div class="flex items-center border-b border-white/[0.06] px-5 py-3">
    <div class="flex gap-2">
      <div class="h-3 w-3 rounded-full bg-white/[0.08]"></div>
      <div class="h-3 w-3 rounded-full bg-white/[0.08]"></div>
      <div class="h-3 w-3 rounded-full bg-white/[0.08]"></div>
    </div>
    <span class="mx-auto font-mono text-[11px] font-medium tracking-wide text-white/25 uppercase">{title}</span>
    <div class="w-[48px]"></div>
  </div>
  <div class="code-content max-h-[320px] overflow-auto px-5 py-4 text-[13px] leading-relaxed">
    <Code code={code.trim()} lang={lang} theme="github-dark" />
  </div>
</div>

<style>
  .code-content :global(pre) {
    background: transparent !important;
    margin: 0;
    padding: 0;
  }
  .code-content :global(code) {
    background: transparent !important;
  }
</style>
