---
import { Code } from "astro:components";

interface Props {
  title: string;
  code: string;
  lang?: string;
}

const { title, code, lang = "typescript" } = Astro.props;
---

<div class="code-frame flex w-full flex-col rounded-lg border border-white/[0.06] bg-[#0d1117]">
  <div class="flex items-center border-b border-white/[0.06] px-4 py-2.5">
    <div class="flex gap-1.5">
      <div class="h-3 w-3 rounded-full bg-[#ff5f57]"></div>
      <div class="h-3 w-3 rounded-full bg-[#febc2e]"></div>
      <div class="h-3 w-3 rounded-full bg-[#28c840]"></div>
    </div>
    <span class="mx-auto text-xs font-medium text-white/40">{title}</span>
    <div class="w-[54px]"></div>
  </div>
  <div class="code-content overflow-auto p-4 text-[13px] leading-relaxed">
    <Code code={code.trim()} lang={lang} theme="github-dark" />
  </div>
</div>

<style>
  .code-content :global(pre) {
    background: transparent !important;
    margin: 0;
    padding: 0;
  }
  .code-content :global(code) {
    background: transparent !important;
  }
</style>
