---
interface Props {
  step: string;
  title: string;
  description: string;
  status: "ready" | "soon";
  statusLabel: string;
  commands: { prompt?: string; text: string; tone?: "brand" | "info" | "fg-faint" }[];
  muted?: boolean;
}

const { step, title, description, status, statusLabel, commands, muted = false } = Astro.props;

const toneMap = {
  brand: "text-brand/50",
  info: "text-info/50",
  "fg-faint": "text-fg-faint",
} as const;
---

<div class:list={["frame flex flex-col gap-5 p-6 transition-colors duration-300", muted && "opacity-60 hover:opacity-75", !muted && "hover:border-border-strong"]}>
  <div class="flex items-center gap-2.5">
    {status === "ready" ? (
      <span class="pulse-dot h-2 w-2 rounded-full bg-success"></span>
    ) : (
      <span class="h-2 w-2 rounded-full bg-fg-faint"></span>
    )}
    <span class:list={["font-mono text-[10px] uppercase tracking-[0.18em]", status === "ready" ? "text-success/70" : "text-fg-faint"]}>
      {statusLabel}
    </span>
  </div>

  <div class="flex flex-col gap-1.5">
    <div class="flex items-baseline gap-3">
      <span class="font-mono text-[11px] text-fg-faint">{step}</span>
      <h3 class="text-xl font-semibold text-fg">{title}</h3>
    </div>
    <p class="text-sm leading-relaxed text-fg-subtle">{description}</p>
  </div>

  <div class="mt-auto flex flex-col gap-1 rounded-xl border border-hairline bg-bg/60 px-4 py-3 font-mono text-[13px] leading-relaxed text-fg-subtle">
    {commands.map((c) => (
      <div>
        <span class:list={[toneMap[c.tone ?? "fg-faint"]]}>{c.prompt ?? "❯"}</span>
        <span>&nbsp;{c.text}</span>
      </div>
    ))}
  </div>
</div>
