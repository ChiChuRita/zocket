---
import { Button } from "./ui/button";
const date = new Date().getFullYear();
---

<footer class="container">
  <div class="flex flex-col items-center justify-center gap-4 pt-20">
    <div class="flex flex-row items-center gap-2">
      <a href="/" class="flex items-center gap-2">
        <img src="/favicon.svg" alt="Zocket logo" class="h-8 w-8" />
        <h2>Zocket</h2>
      </a>
    </div>
    <div class="text-center">
      Copyright &copy; {date} Zocket. All rights reserved.
    </div>
    <div class="flex flex-row">
      <a href="https://github.com/ChiChuRita/zocket">
        <Button size="sm" className="xl:text-base text-sm" variant="ghost">
          GitHub
        </Button>
      </a>
      <a href="/getting-started/">
        <Button size="sm" className="xl:text-base text-sm" variant="ghost">
          Documentation
        </Button>
      </a>
    </div>
  </div>
</footer>
