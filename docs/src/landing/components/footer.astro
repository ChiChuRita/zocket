---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-4 px-6 py-12">
    <a href="/" class="flex items-center gap-2.5 transition-opacity hover:opacity-80">
      <img src="/favicon.svg" alt="Zocket logo" class="h-6 w-6" />
      <span class="text-base font-semibold text-fg">Zocket</span>
    </a>
    <div class="flex gap-6 text-sm text-fg-subtle">
      <a href="https://github.com/ChiChuRita/zocket" class="transition-colors hover:text-fg">
        GitHub
      </a>
      <a href="/getting-started/" class="transition-colors hover:text-fg">
        Documentation
      </a>
    </div>
    <p class="text-xs text-fg-faint">
      Made with 🧦 and TypeScript · © {year} Zocket
    </p>
  </div>
</footer>
