---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.08]">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-6 py-12">
    <a href="/" class="flex items-center gap-2.5 transition-opacity hover:opacity-80">
      <img src="/favicon.svg" alt="Zocket logo" class="h-6 w-6" />
      <span class="text-base font-semibold text-white">Zocket</span>
    </a>
    <div class="flex gap-5 text-sm text-white/35">
      <a href="https://github.com/ChiChuRita/zocket" class="transition-colors hover:text-white/70">GitHub</a>
      <a href="/getting-started/" class="transition-colors hover:text-white/70">Documentation</a>
    </div>
    <p class="text-xs text-white/25">
      Made with 🧦 and TypeScript &middot; &copy; {year} Zocket
    </p>
  </div>
</footer>
