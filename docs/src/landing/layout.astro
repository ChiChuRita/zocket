---
import "@fontsource-variable/inter";
import "@fontsource/jetbrains-mono";

import "./global.css";
import Navbar from "./components/navbar.astro";
import Footer from "./components/footer.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Typed actor runtime for realtime applications. Define actors, call methods, subscribe to state — all end-to-end type-safe." />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content="Zocket" />
    <meta property="og:description" content="Typed actor runtime for realtime applications" />
    <title>Zocket</title>
  </head>
  <body class="flex flex-col justify-between font-sans">
    <Navbar />
    <div class="flex flex-col justify-center gap-20 p-6 xl:container">
      <slot />
    </div>
    <div class="p-6">
      <Footer />
    </div>
  </body>
</html>
