---
const features = ["Timers", "Cron", "Actor-to-Actor", "Streaming", "AI SDK Integration"];
---

<section class="reveal relative flex flex-col items-center gap-5 text-center" data-accent="pink">
  <div class="section-glow" aria-hidden="true"></div>
  <h2 class="text-2xl md:text-3xl">
    Coming <span class="text-accent-pink">soon</span>
  </h2>

  <div class="flex flex-wrap justify-center gap-2.5">
    {features.map((f) => (
      <a href="/roadmap/" class="tag-pill">{f}</a>
    ))}
  </div>

  <p class="text-sm text-fg-faint">
    These features are designed and in progress.
    <a href="/roadmap/" class="text-brand/70 transition-colors hover:text-brand">
      Read the roadmap &rarr;
    </a>
  </p>
</section>

<style>
  .roadmap-tag:hover {
    border-color: var(--tag-accent-border);
    background: var(--tag-accent-soft);
    color: var(--tag-accent-strong);
  }
</style>
