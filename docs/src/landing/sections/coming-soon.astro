---
const features = ["Timers", "Cron", "Actor-to-Actor", "Streaming", "AI SDK Integration"];
---

<section class="reveal relative flex flex-col items-center gap-5 text-center">
  <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
    Coming <span class="text-primary">soon</span>
  </h2>

  <div class="flex flex-wrap justify-center gap-2.5">
    {features.map((f) => (
      <a
        href="/roadmap/"
        class="roadmap-tag rounded-full border border-white/[0.08] bg-white/[0.03] px-4 py-1.5 font-mono text-xs text-white/50 transition-all duration-300 hover:border-primary/30 hover:bg-primary/[0.04] hover:text-primary/80"
      >
        {f}
      </a>
    ))}
  </div>

  <p class="text-sm text-white/35">
    These features are designed and in progress.
    <a href="/roadmap/" class="text-primary/60 transition-colors hover:text-primary">
      Read the roadmap &rarr;
    </a>
  </p>
</section>
