---
import { Button } from "../components/ui/button";
---

<section class="reveal relative flex flex-col items-center gap-6 text-center">
  <div class="section-glow bg-primary"></div>

  <div class="terminal-cursor flex items-center gap-2 rounded-lg border border-white/[0.06] bg-white/[0.03] px-5 py-3 font-mono text-sm text-white/40">
    <span class="text-primary/60">$</span>
    <span>bun add @zocket/core @zocket/server @zocket/client zod</span>
  </div>

  <a href="/getting-started/" class="w-fit">
    <Button className="text-base px-8" size="lg">
      Read the Docs
    </Button>
  </a>
</section>
