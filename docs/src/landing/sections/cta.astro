---
import { Button } from "../components/ui/button";

const installCommand = "bun add @zocket/core @zocket/server @zocket/client zod";
---

<section
  class="reveal relative flex flex-col items-center gap-6 text-center"
  style="--section-accent: hsl(30 100% 50%);"
>
  <div class="section-glow" style="background: var(--section-accent);"></div>

  <div
    id="install-command-line"
    class="terminal-cursor flex items-center gap-3 rounded-lg border border-white/[0.06] bg-white/[0.03] px-5 py-3 font-mono text-sm text-white/40 transition-all duration-300"
  >
    <span class="text-primary/60">$</span>
    <div class="terminal-loop-viewport">
      <div class="terminal-loop-track">
        <span class="terminal-loop-copy">{installCommand}</span>
        <span class="terminal-loop-copy" aria-hidden="true">{installCommand}</span>
      </div>
    </div>
  </div>

  <Button
    id="copy-install-command"
    className="text-base px-8 transition-transform duration-200"
    size="lg"
    type="button"
    data-command={installCommand}
  >
    Copy Command
  </Button>
</section>

<script>
  const button = document.querySelector("#copy-install-command");
  const commandLine = document.querySelector("#install-command-line");

  if (button instanceof HTMLButtonElement && commandLine instanceof HTMLElement) {
    const defaultLabel = "Copy Command";
    let resetTimer: number | undefined;

    button.addEventListener("click", async () => {
      const command = button.dataset.command;
      if (!command) return;

      try {
        await navigator.clipboard.writeText(command);

        window.clearTimeout(resetTimer);
        button.textContent = "Copied";
        button.classList.add("copy-feedback-active");
        commandLine.classList.add("copy-feedback-active");

        resetTimer = window.setTimeout(() => {
          button.textContent = defaultLabel;
          button.classList.remove("copy-feedback-active");
          commandLine.classList.remove("copy-feedback-active");
        }, 1400);
      } catch {
        button.textContent = "Copy failed";

        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.textContent = defaultLabel;
        }, 1400);
      }
    });
  }
</script>
