---
import { buttonVariants } from "../components/ui/button";
---

<section class="reveal relative flex flex-col items-center gap-6 text-center" data-accent="brand">
  <div class="section-glow" aria-hidden="true"></div>
  <div class="terminal-cursor flex items-center gap-2 rounded-xl border border-border bg-surface/60 px-5 py-3 font-mono text-sm text-fg-subtle">
    <span class="text-brand/70">$</span>
    <span>bun add @zocket/core @zocket/server @zocket/client zod</span>
  </div>

  <a href="/getting-started/" class={buttonVariants({ size: "lg" })}>Read the Docs</a>
</section>

<script>
  const button = document.querySelector("#copy-install-command");
  const commandLine = document.querySelector("#install-command-line");

  if (button instanceof HTMLButtonElement && commandLine instanceof HTMLElement) {
    const defaultLabel = "Copy Command";
    let resetTimer: number | undefined;

    button.addEventListener("click", async () => {
      const command = button.dataset.command;
      if (!command) return;

      try {
        await navigator.clipboard.writeText(command);

        window.clearTimeout(resetTimer);
        button.textContent = "Copied";
        button.classList.add("copy-feedback-active");
        commandLine.classList.add("copy-feedback-active");

        resetTimer = window.setTimeout(() => {
          button.textContent = defaultLabel;
          button.classList.remove("copy-feedback-active");
          commandLine.classList.remove("copy-feedback-active");
        }, 1400);
      } catch {
        button.textContent = "Copy failed";

        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.textContent = defaultLabel;
        }, 1400);
      }
    });
  }
</script>
