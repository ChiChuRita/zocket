---
// Two-column editorial: sticky headline on the left, hairline-divided
// feature list on the right.
import { features } from "./features-data";
import FeatureIcon from "../components/feature-icon.astro";
---

<section class="relative flex flex-col gap-8" data-accent="pink">
  <div class="section-glow" aria-hidden="true"></div>

  <div class="reveal grid gap-10 md:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] md:gap-16">
    <header class="flex flex-col gap-4 md:sticky md:top-24 md:self-start">
      <h2>
        Everything realtime apps need, <span class="text-accent-pink">in one runtime.</span>
      </h2>
      <p class="text-base text-fg-muted md:text-[1.0625rem]">
        No separate database service, no queue, no socket server, no scheduler to manage.
      </p>
    </header>

    <div class="flex flex-col">
      {features.map((f, i) => (
        <div
          class:list={[
            "flex gap-4 py-5",
            i !== 0 && "border-t border-hairline",
          ]}
        >
          <span
            class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-surface-2 text-accent-pink"
            aria-hidden="true"
          >
            <FeatureIcon icon={f.icon} size={16} />
          </span>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-[15px] font-semibold text-fg">{f.title}</h3>
            <p class="text-sm leading-relaxed text-fg-muted">{f.blurb}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
