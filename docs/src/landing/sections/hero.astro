---
import { Button } from "../components/ui/button";
import CodeBlock from "../components/code-block.astro";

const serverCode = `import { actor, createApp, serve } from "@zocket/core";
import { z } from "zod";

const ChatRoom = actor({
  state: z.object({
    messages: z.array(z.object({
      from: z.string(), text: z.string(),
    })).default([]),
  }),
  methods: {
    send: {
      input: z.object({ from: z.string(), text: z.string() }),
      handler: ({ state, input }) => { state.messages.push(input) },
    },
  },
});

export const app = createApp({ actors: { chat: ChatRoom } });
serve(app, { port: 3000 });`;

const clientCode = `import { createClient } from "@zocket/client";
import type { app } from "./server";

const client = createClient<typeof app>({
  url: "ws://localhost:3000",
});

const room = client.chat("general");

await room.send({ from: "alice", text: "hello!" });

room.state.subscribe((s) => {
  console.log(s.messages);
  // → [{ from: "alice", text: "hello!" }]
});`;
---

<section class="relative flex flex-col gap-10 xl:gap-14">
  <div class="dot-grid pointer-events-none absolute inset-0 -z-20 opacity-50"></div>
  <div
    class="orb"
    style="--orb-top: 10%; --orb-left: 12%; --orb-size: 50%; --orb-tx: 0; --orb-ty: 0; --orb-blur: 120px;"
  ></div>

  <header class="relative grid gap-10 xl:grid-cols-[minmax(0,1.1fr)_minmax(280px,420px)] xl:items-center xl:gap-12">
    <div class="stagger flex flex-col gap-5">
      <div class="eyebrow">Realtime infrastructure</div>

      <h1 class="max-w-[12ch]">
        Serverless realtime backends,
        <span class="shimmer-text tracking-[-0.045em]">fully typed.</span>
      </h1>

      <p class="max-w-xl text-base leading-relaxed text-fg-muted xl:text-[1.0625rem]">
        Use your schema library of choice, connect from typed clients, and keep realtime state in sync without socket boilerplate.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <Button size="lg" asChild>
          <a href="/getting-started/">Get Started</a>
        </Button>
        <Button size="lg" variant="secondary" asChild>
          <a href="https://github.com/ChiChuRita/zocket">
            <img src="/github-mark-white.svg" class="h-5 w-5" alt="" aria-hidden="true" />
            GitHub
          </a>
        </Button>
      </div>
    </div>

    <div class="hero-socks relative mx-auto hidden w-full max-w-[420px] aspect-square items-center justify-center xl:flex">
      <div class="frame absolute inset-0"></div>
      <div
        class="orb"
        style="--orb-top: 32%; --orb-left: 30%; --orb-size: 70%; --orb-color: color-mix(in oklab, var(--color-brand) 14%, transparent); --orb-tx: 0; --orb-ty: 0; --orb-blur: 30px;"
      ></div>
      <div class="absolute inset-[12%] rounded-full border border-border bg-[radial-gradient(circle_at_center,color-mix(in_oklab,var(--color-fg)_2%,transparent),transparent_65%)]"></div>

      <img
        src="/sock1.svg"
        alt=""
        aria-hidden="true"
        class="anim-sock-left absolute left-[25%] top-[20%] w-[38%] drop-shadow-[0_22px_40px_rgba(0,0,0,0.35)] z-[2] will-change-transform"
      />
      <img
        src="/sock2.svg"
        alt=""
        aria-hidden="true"
        class="anim-sock-right absolute right-[24%] top-[24%] w-[39%] drop-shadow-[0_22px_40px_rgba(0,0,0,0.35)] z-[1] will-change-transform"
      />

      <div class="absolute left-1/2 bottom-5 -translate-x-1/2 inline-flex items-center gap-2 rounded-full border border-border bg-bg/60 px-3 py-2 font-mono text-[0.625rem] uppercase tracking-[0.16em] text-fg-subtle backdrop-blur">
        <span class="h-1.5 w-1.5 rounded-full bg-brand/80"></span>
        Stateful pair
      </div>
    </div>
  </header>

  <!-- Code showcase -->
  <div class="fade-up-delayed relative">
    <div
      class="orb"
      style="--orb-top: 50%; --orb-left: 50%; --orb-size: 80%; --orb-color: color-mix(in oklab, var(--color-brand) 6%, transparent); --orb-blur: 120px;"
    ></div>

    <div class="flex flex-col gap-4 xl:flex-row xl:items-stretch xl:gap-6">
      <div class="min-w-0 flex-1">
        <CodeBlock title="server.ts" code={serverCode} />
      </div>

      <div class="flex justify-center xl:flex-col xl:items-center xl:py-8">
        <div class="inline-flex items-center gap-1.5 rounded-full border border-brand/20 bg-brand/5 px-3 py-1 transition-colors duration-300 hover:border-brand/40 hover:bg-brand/10">
          <svg
            class="h-3.5 w-3.5 text-brand anim-nudge-right xl:rotate-0 rotate-90"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          <span class="font-mono text-[10px] tracking-wider text-brand/80 uppercase">types</span>
        </div>
        <div class="hidden xl:block h-full w-px bg-gradient-to-b from-transparent via-brand/25 to-transparent mt-3"></div>
      </div>

      <div class="min-w-0 flex-1">
        <CodeBlock title="client.ts" code={clientCode} />
      </div>
    </div>
  </div>
</section>
