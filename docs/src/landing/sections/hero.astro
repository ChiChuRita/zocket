---
import { Button } from "../components/ui/button";
import CodeBlock from "../components/code-block.astro";

const serverCode = `import { actor, createApp, serve } from "@zocket/core";
import { z } from "zod";

const ChatRoom = actor({
  state: z.object({
    messages: z.array(z.object({
      from: z.string(), text: z.string(),
    })).default([]),
  }),
  methods: {
    send: {
      input: z.object({ from: z.string(), text: z.string() }),
      handler: ({ state, input }) => { state.messages.push(input) },
    },
  },
});

export const app = createApp({ actors: { chat: ChatRoom } });
serve(app, { port: 3000 });`;

const clientCode = `import { createClient } from "@zocket/client";
import type { app } from "./server";

const client = createClient<typeof app>({
  url: "ws://localhost:3000",
});

const room = client.chat("general");

await room.send({ from: "alice", text: "hello!" });

room.state.subscribe((s) => {
  console.log(s.messages);
  // → [{ from: "alice", text: "hello!" }]
});`;
---

<section class="relative flex flex-col gap-10 xl:gap-12">
  <div class="dot-grid pointer-events-none absolute inset-0 -z-20 opacity-60"></div>
  <div class="hero-orb"></div>

  <header class="relative grid gap-8 xl:grid-cols-[minmax(0,1.1fr)_minmax(280px,420px)] xl:items-center xl:gap-10">
    <div class="hero-stagger relative flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <span class="h-px w-10 bg-gradient-to-r from-primary/80 to-transparent"></span>
        <span class="font-mono text-[11px] uppercase tracking-[0.24em] text-primary/70">
          Realtime infrastructure
        </span>
      </div>
      <h1 class="max-w-[11ch] text-4xl font-bold tracking-tight text-white md:text-5xl xl:text-[3.75rem] xl:leading-[0.98]">
        Serverless realtime backends,
        <span class="shimmer-text block font-mono tracking-normal">fully typed.</span>
      </h1>
      <h3 class="max-w-xl text-base leading-relaxed text-white/62 xl:text-[1.0625rem]">
        Use your schema library of choice, connect from typed clients, and keep realtime state in sync without socket boilerplate.
      </h3>
      <div class="flex flex-row gap-4 pt-2">
        <a href="/getting-started/" class="w-fit">
          <Button className="w-fit text-base px-6" size="lg">
            Get Started
          </Button>
        </a>
        <a href="https://github.com/ChiChuRita/zocket" class="flex w-fit">
          <Button
            variant={"secondary"}
            className="w-fit text-base flex gap-3 px-6"
            size="lg"
          >
            <img src="/github-mark-white.svg" class="w-6" alt="GitHub logo" />
            GitHub
          </Button>
        </a>
      </div>
    </div>

    <div class="hero-socks-frame relative mx-auto hidden w-full max-w-[420px] items-center justify-center xl:flex">
      <div class="hero-socks-glow"></div>
      <div class="hero-socks-ring"></div>
      <img src="/sock1.svg" alt="" aria-hidden="true" class="hero-sock hero-sock-left" />
      <img src="/sock2.svg" alt="" aria-hidden="true" class="hero-sock hero-sock-right" />
      <div class="hero-socks-badge">
        <span class="h-2 w-2 rounded-full bg-primary/80"></span>
        Stateful pair
      </div>
    </div>
  </header>

  <!-- Code showcase -->
  <div class="hero-code-entrance relative">
    <div class="hero-code-glow"></div>

    <div class="flex flex-col gap-5 xl:flex-row xl:items-stretch xl:gap-6">
      <div class="hero-code-block flex-1 min-w-0">
        <CodeBlock title="server.ts" code={serverCode} />
      </div>

      <!-- Type flow connector — desktop -->
      <div class="hidden xl:flex flex-col items-center justify-center gap-3 py-8">
        <div class="type-pill flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/5 px-3 py-1">
          <svg class="h-3.5 w-3.5 text-primary type-nudge" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
          <span class="font-mono text-[10px] tracking-wider text-primary/70 uppercase">types</span>
        </div>
        <div class="h-full w-px bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
      </div>

      <!-- Type flow connector — mobile -->
      <div class="flex xl:hidden items-center justify-center py-1">
        <div class="type-pill flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/5 px-3 py-1">
          <svg class="h-3.5 w-3.5 text-primary rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
          <span class="font-mono text-[10px] tracking-wider text-primary/70 uppercase">types</span>
        </div>
      </div>

      <div class="hero-code-block flex-1 min-w-0">
        <CodeBlock title="client.ts" code={clientCode} />
      </div>
    </div>
  </div>
</section>

<style>
  /* Ambient orb behind the hero — warm, diffuse */
  .hero-orb {
    position: absolute;
    top: -15%;
    left: -10%;
    width: 60%;
    height: 120%;
    background: radial-gradient(
      ellipse at 30% 40%,
      hsl(30 100% 50% / 0.05) 0%,
      hsl(30 100% 50% / 0.02) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -10;
  }

  /* Code entrance — delayed after hero header stagger */
  .hero-code-entrance {
    opacity: 0;
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.5s;
  }

  .hero-socks-frame {
    min-height: 320px;
    border-radius: 2rem;
    border: 1px solid rgb(255 255 255 / 0.06);
    background:
      radial-gradient(circle at 30% 35%, hsl(30 100% 50% / 0.12), transparent 35%),
      radial-gradient(circle at 70% 65%, rgb(255 255 255 / 0.03), transparent 30%),
      linear-gradient(180deg, rgb(255 255 255 / 0.04), rgb(255 255 255 / 0.02));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.04),
      0 30px 90px rgb(0 0 0 / 0.35);
    overflow: hidden;
    backdrop-filter: blur(18px);
  }

  .hero-socks-glow {
    position: absolute;
    inset: auto auto 18% 50%;
    width: 70%;
    height: 22%;
    transform: translateX(-50%);
    border-radius: 999px;
    background: radial-gradient(ellipse at center, hsl(30 100% 50% / 0.22), transparent 70%);
    filter: blur(20px);
  }

  .hero-socks-ring {
    position: absolute;
    inset: 12% 16%;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.05);
    background: radial-gradient(circle at center, rgb(255 255 255 / 0.02), transparent 65%);
  }

  .hero-sock {
    position: absolute;
    width: 46%;
    max-width: 200px;
    will-change: transform;
    filter: drop-shadow(0 22px 40px rgb(0 0 0 / 0.35));
  }

  .hero-sock-left {
    left: 25%;
    top: 20%;
    width: 38%;
    transform: rotate(-32deg);
    transform-origin: 62% 28%;
    animation: sock-rotate-left 4.8s ease-in-out infinite;
    z-index: 2;
  }

  .hero-sock-right {
    right: 24%;
    top: 24%;
    width: 39%;
    transform: rotate(28deg);
    transform-origin: 38% 28%;
    animation: sock-rotate-right 4.8s ease-in-out infinite;
    z-index: 1;
  }

  .hero-socks-badge {
    position: absolute;
    left: 50%;
    bottom: 1.15rem;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.08);
    background: rgb(9 9 9 / 0.55);
    padding: 0.45rem 0.8rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.55);
    backdrop-filter: blur(10px);
  }

  /* Ambient glow behind code blocks */
  .hero-code-glow {
    position: absolute;
    inset: -25%;
    z-index: -1;
    background: radial-gradient(
      ellipse at 50% 50%,
      hsl(30 100% 50% / 0.07) 0%,
      hsl(30 100% 50% / 0.03) 30%,
      transparent 65%
    );
    pointer-events: none;
  }

  /* Allow hero code blocks full height — don't clip */
  .hero-code-block :global(.code-content) {
    max-height: 420px;
  }

  /* Type flow pill glow on hover */
  .type-pill {
    transition: all 0.3s ease;
  }
  .type-pill:hover {
    background: hsl(30 100% 50% / 0.1);
    border-color: hsl(30 100% 50% / 0.35);
    box-shadow: 0 0 16px hsl(30 100% 50% / 0.1);
  }

  @keyframes nudge-right {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(3px); }
  }
  .type-nudge {
    animation: nudge-right 2s ease-in-out infinite;
  }

  @keyframes sock-rotate-left {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-32deg); }
    50% { transform: translate3d(-4px, -8px, 0) rotate(-20deg); }
  }

  @keyframes sock-rotate-right {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(28deg); }
    50% { transform: translate3d(5px, -9px, 0) rotate(14deg); }
  }
</style>
