---
import DeployCard from "../components/deploy-card.astro";
---

<section class="relative flex flex-col gap-8">
  <header class="reveal flex flex-col gap-3">
    <h2>
      How it <span class="text-accent-violet">runs</span>
    </h2>
    <p class="max-w-2xl text-base text-fg-muted md:text-lg">
      Start with one process. Scale to a distributed cluster when you need it.
    </p>
  </header>

  <div class="reveal grid gap-5 md:grid-cols-3">
    <DeployCard
      step="01"
      title="Standalone"
      description="One process, zero infra. For prototypes and small apps."
      status="ready"
      statusLabel="ready"
      commands={[{ text: "serve(app, { port: 3000 })", tone: "brand" }]}
    />

    <DeployCard
      step="02"
      title="Distributed"
      description="Gateway + NATS + runtime. Self-hosted, scales independently."
      status="ready"
      statusLabel="ready"
      commands={[
        { text: "docker compose up", tone: "info" },
        { text: "zocket deploy", tone: "info" },
      ]}
    />

    <DeployCard
      step="03"
      title="Platform"
      description="Multi-tenant, Firecracker isolation, fully hosted."
      status="soon"
      statusLabel="coming soon"
      muted
      commands={[{ text: "zocket deploy --platform", tone: "brand" }]}
    />
  </div>
</section>
