---
import { UseCasesBrowser } from "../components/use-cases-browser";
---

<section class="relative flex flex-col gap-6">
  <div class="section-glow bg-primary"></div>

  <header class="reveal flex flex-col">
    <span class="usecase-kicker mb-2 w-fit border border-primary/20 bg-primary/8 px-4 py-1 text-[11px] font-mono uppercase tracking-[0.16em] text-primary/80">
      see the fit
    </span>
    <h1>one runtime, many <span class="text-primary">realtime products</span></h1>
    <h3 class="max-w-2xl">
      The same serverless DX works across threads, agents, rooms, workflows,
      and collaborative state. If a part of your product needs to stay live
      over time, Zocket gives it a direct runtime shape.
    </h3>
  </header>

  <div class="reveal">
    <UseCasesBrowser client:visible />
  </div>
</section>
