{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@zocket/client": ["../../packages/client/src/index.ts"],
      "@zocket/core": ["../../packages/core/src/index.ts"],
      "@zocket/core/protocol": ["../../packages/core/src/protocol.ts"],
      "@zocket/core/types": ["../../packages/core/src/types.ts"],
      "@zocket/server": ["../../packages/server/src/index.ts"],
      "@zocket/server/bun": ["../../packages/server/src/bun.ts"]
    },
    "types": ["bun"]
  },
  "include": ["overview.ts"]
}
