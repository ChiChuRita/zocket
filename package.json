{
  "name": "zocket",
  "type": "module",
  "scripts": {
    "build": "bun run --workspaces build",
    "clean": "bunx tsdown -W --clean",
    "changeset": "changeset",
    "docs:deploy": "bun run --cwd docs deploy",
    "docs:dev": "bun run --cwd docs dev",
    "aws:on": "bun --cwd infra/pulumi-aws run up -- --stack dev",
    "aws:off": "bun --cwd infra/pulumi-aws run destroy -- --stack dev",
    "cloudflare:sync": "bun --cwd infra/pulumi-cloudflare run up -- --stack dev",
    "neon:up": "bun --cwd infra/pulumi-neon run up -- --stack dev",
    "platform:dev": "bun ./scripts/platform-dev.ts",
    "platform:deploy": "bun ./scripts/platform-push.ts",
    "platform:push": "bun run platform:deploy",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "tsdown": "^0.16.1",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "old/*",
    "packages/*",
    "docs",
    "platform",
    "examples/*",
    "examples/*/client"
  ]
}
